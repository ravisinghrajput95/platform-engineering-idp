# Copy to .env and fill in for `docker compose up` (see docker-compose.yaml).
# These are the same keys as the backstage-secrets k8s Secret in the GKE deployment.

POSTGRES_PASSWORD=

# GitHub PAT with `repo` scope -- used by the scaffolder's publish:github action
# and the catalog's GitHub integration.
GITHUB_TOKEN=

# GitHub OAuth App credentials, used for sign-in.
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# Optional -- the argocd integration won't be reachable locally anyway (its URL is
# cluster-internal DNS). Leave blank and docker-compose.yaml will substitute a
# placeholder; the plugin's config schema rejects an empty string outright.
ARGOCD_AUTH_TOKEN=
